# ─── FLEETWATCH — Fleet Intelligence Platform ─────────────────────────────────
# Environment Configuration
# Copy to .env.local and fill in values

# ─── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:4005
NEXT_PUBLIC_APP_NAME=FLEETWATCH
NEXT_PUBLIC_APP_ENV=development

# ─── API ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api
API_KEY=

# ─── Map Services (Fleet Tracking) ────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ─── Real-Time / WebSocket ────────────────────────────────────────────────────
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_TELEMETRY_INTERVAL_MS=3000

# ─── Observability ────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_SENTRY_DSN=

# ─── External Integrations ────────────────────────────────────────────────────
NEXT_PUBLIC_WEATHER_API_KEY=
NEXT_PUBLIC_TRAFFIC_API_KEY=

# ─── Auth (Optional) ──────────────────────────────────────────────────────────
AUTH_SECRET=
AUTH_URL=http://localhost:4005

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/fleetwatch
REDIS_URL=redis://localhost:6379
